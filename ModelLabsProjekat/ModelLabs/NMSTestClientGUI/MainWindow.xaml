<Window x:Class="NMSTestClientGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NMSTestClientGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1F2937" Offset="0"/>
            <GradientStop Color="#111827" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="RichTextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="LightBlue"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#020617"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="GetValues">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Global ID:" Grid.Row="0" Grid.Column="0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbGetValuesGid" Height="30" Width="650" Margin="0,0,0,10" Background="#111827" Foreground="White"/>
                            <Button x:Name="BtnGetValues" Content="Get Values" Click="BtnGetValues_Click" Grid.Row="1" Grid.ColumnSpan="2"/>
                            <!--Button Grid.Column="1" x:Name="BtnScan" Content="Get Scan" Click="BtnScan_Click" Grid.Row="1" Grid.ColumnSpan="1"/-->
                        </Grid>
                    </StackPanel>

                    <RichTextBox x:Name="RtbGetValues" Grid.Row="1"/>
                </Grid>
            </TabItem>

            <TabItem Header="GetExtentValues">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Label Content="ModelCode:"/>
                        <TextBox x:Name="TbExtentModelCode"/>
                        <Button x:Name="BtnGetExtent" Content="Get Extent" Click="BtnGetExtent_Click"/>
                    </StackPanel>

                    <RichTextBox x:Name="RtbExtentValues" Grid.Row="1"/>
                </Grid>
            </TabItem>

            <TabItem Header="GetRelatedValues">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Label Content="Source GID:"/>
                        <TextBox x:Name="TbSourceGid"/>
                        <Label Content="Association Property:"/>
                        <TextBox x:Name="TbAssociationProperty"/>
                        <Label Content="Association Type:"/>
                        <TextBox x:Name="TbAssociationType"/>
                        <Button x:Name="BtnGetRelated" Content="Get Related" Click="BtnGetRelated_Click"/>
                    </StackPanel>

                    <RichTextBox x:Name="RtbRelatedValues" Grid.Row="1"/>
                </Grid>
            </TabItem>

            <TabItem Header="ACLineSegment and Clamp">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Label Content="ACLineSegment GID:"/>
                        <TextBox x:Name="TbAclineGid"/>
                        <Button x:Name="BtnGetClamps" Content="Get Clamps" Click="BtnGetClamps_Click"/>
                        <Button x:Name="BtnClampMinLength" Content="Clamp With Min Length" Click="BtnClampMinLength_Click"/>
                    </StackPanel>

                    <RichTextBox x:Name="RtbClamps" Grid.Row="1"/>
                </Grid>
            </TabItem>

            <TabItem Header="Terminals">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Label Content="ConductingEquipment GID:"/>
                        <TextBox x:Name="TbCondEqGid"/>
                        <Button x:Name="BtnGetTerminals" Content="Get Terminals" Click="BtnGetTerminals_Click"/>
                        <Button x:Name="BtnDisconnectedTerminals" Content="Disconnected Terminals" Click="BtnDisconnectedTerminals_Click"/>
                    </StackPanel>

                    <RichTextBox x:Name="RtbTerminals" Grid.Row="1"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
